{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=your_db_name;Username=your_username;Password=your_password"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "your_super_long_and_secure_secret_key",
    "Issuer": "your_issuer",
    "Audience": "your_audience",
    "ExpirationDays": 1
  },
  "Email": {
    "SmtpServer": "smtp.example.com",
    "SmtpPort": 587,
    "SenderEmail": "sender@example.com",
    "SenderPassword": "your_password",
    "Login": "sender@example.com"
  },
  "PasswordHasher": {
    "SaltSize": 16,
    "HashSize": 32,
    "Parallelism": 8,
    "MemorySize": 65536,
    "Iterations": 4
  },
  "AppConfig": {
    "BaseUrl": "https://localhost:7000"
  }
}
